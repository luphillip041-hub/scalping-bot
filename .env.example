# Alpaca API (paper trading keys recommended)
ALPACA_API_KEY=your_key_here
ALPACA_API_SECRET=your_secret_here
ALPACA_PAPER=true

# Universe (40-day backtest: these three carry the edge)
SYMBOLS=AAPL,TSLA,META

# Strategy (backtest-tuned defaults)
BAR_TIMEFRAME=1Min
VWAP_MIN_DISTANCE_PCT=0.05
VOLUME_SPIKE_MULT=2.0
MOMENTUM_LOOKBACK=5
TAKE_PROFIT_PCT=0.5
STOP_LOSS_PCT=0.3
MAX_HOLD_MINUTES=15

# Risk
POSITION_SIZE_USD=2000
MAX_POSITIONS=3
MAX_DAILY_LOSS_USD=150
MAX_TRADES_PER_DAY=25

# Session (ET)
TRADE_START=09:35
TRADE_END=15:50
POLL_SECONDS=20
